# Google Sheets API
GOOGLE_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_KEY=

# Database
# Local: DATABASE_URL=file:./argos.db
# Produção (Turso): DATABASE_URL=libsql://seu-banco.turso.io
DATABASE_URL=file:./argos.db

# Turso auth token (somente em produção)
TURSO_AUTH_TOKEN=

# Auth
# Gere com: openssl rand -base64 32
AUTH_SECRET=

# Domínio(s) de e-mail autorizado(s) — separar múltiplos por vírgula
ALLOWED_EMAIL_DOMAINS=pmenos.com.br

# Duração da sessão em dias (padrão: 7)
SESSION_DURATION_DAYS=7

# Tempo de bloqueio após tentativas falhas de recuperação de senha (em minutos, padrão: 30)
AUTH_LOCKOUT_MINUTES=30
